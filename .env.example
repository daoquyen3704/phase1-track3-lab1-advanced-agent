# Copy this file to .env and fill only the provider you use.

# Runtime mode
# mock: use src/reflexion_lab/mock_runtime.py deterministic scaffold
# openai/gemini/ollama/vllm/dashscope: use a real LLM implementation
LLM_PROVIDER=mock

# Shared generation settings
LLM_MODEL=
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=512
LLM_TIMEOUT_SECONDS=60
LLM_RETRY_ATTEMPTS=4
LLM_RETRY_BACKOFF_SECONDS=2
LLM_REQUEST_DELAY_SECONDS=0

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Ollama local server
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# vLLM / OpenAI-compatible local server
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=

# Qwen / Alibaba DashScope OpenAI-compatible mode
# International examples:
# https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# https://ws-xxxxxxxxxxxxxxxx.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen3.5-35b-a3b
DASHSCOPE_ENABLE_THINKING=false

# Benchmark defaults
DATASET_PATH=data/hotpot_mini.json
OUTPUT_DIR=outputs/sample_run
MAX_ATTEMPTS=3

# Optional debug logging
LOG_LEVEL=INFO
